# .gitignore for FlowGuard AI

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
*.so

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env/

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.local

# ── MLflow ────────────────────────────────────────────────────────────────────
mlruns/
mlartifacts/

# ── BentoML ───────────────────────────────────────────────────────────────────
bentoml/bentos/
.bentoml/

# ── Trained models (large binary files) ──────────────────────────────────────
# Uncomment if you want to exclude model files from git:
# models/*.pkl

# ── Jupyter notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
test-results.xml

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
