// Jenkinsfile
// ─────────────────────────────────────────────────────────────────────────────
// FlowGuard AI – CI/CD Pipeline
//
// This Jenkinsfile defines a declarative pipeline with 6 stages:
//   1. Checkout      – pull source code from Git
//   2. Setup         – create virtual environment and install dependencies
//   3. Test          – run unit tests with pytest
//   4. Generate Data – create synthetic dataset
//   5. Train Model   – baseline + AutoML training with MLflow logging
//   6. Deploy        – serve the model via BentoML
//
// Prerequisites on Jenkins agent:
//   - Python 3.10+ installed
//   - MLflow server running at http://mlflow-server:5000
//   - Agent label: 'ml-agent'
//
// This file is for DESIGN DEMONSTRATION purposes (college MVP).
// No actual Jenkins server is required to view or present this pipeline.
// ─────────────────────────────────────────────────────────────────────────────

pipeline {

    // Run on any agent labeled 'ml-agent' (or 'any' for local testing)
    agent any

    // ── Environment variables ─────────────────────────────────────────────────
    environment {
        APP_NAME        = "flowguard-ai"
        PYTHON_BIN      = "python"
        VENV_DIR        = ".venv"
        MLFLOW_TRACKING = "http://mlflow-server:5000"
        BENTO_PORT      = "3000"
        MODEL_DIR       = "models"
    }

    // ── Pipeline options ──────────────────────────────────────────────────────
    options {
        timeout(time: 45, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
    }

    // ── Trigger: build on every push to main or develop branch ───────────────
    triggers {
        githubPush()
    }

    stages {

        // ── STAGE 1: Checkout ─────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
                checkout scm
                bat 'git log --oneline -5'
            }
        }

        // ── STAGE 2: Setup Environment ────────────────────────────────────────
        stage('Setup Environment') {
            steps {
                echo 'Setting up Python virtual environment...'
                bat """
                    ${PYTHON_BIN} -m venv ${VENV_DIR}
                    call ${VENV_DIR}\\Scripts\\activate.bat
                    python -m pip install --upgrade pip
                    python -m pip install -r requirements.txt
                    echo Dependencies installed
                """
            }
        }

        // ── STAGE 3: Run Tests ────────────────────────────────────────────────
        stage('Test') {
            steps {
                echo 'Running unit tests...'
                bat """
                    call ${VENV_DIR}\\Scripts\\activate.bat
                    pytest tests/ -v --tb=short --junitxml=test-results.xml
                """
            }
            post {
                always {
                    junit 'test-results.xml'
                }
                failure {
                    error 'Unit tests did not pass'
                }
            }
        }

        // ── STAGE 4: Generate Dataset ─────────────────────────────────────────
        stage('Generate Dataset') {
            steps {
                echo 'Generating synthetic SME dataset...'
                bat """
                    call ${VENV_DIR}\\Scripts\\activate.bat
                    python ml/generate_dataset.py
                """
            }
        }

        // ── STAGE 5: Train Model ──────────────────────────────────────────────
        stage('Train Model') {
            steps {
                echo 'Training baseline Random Forest model...'
                // Running just baseline for the Windows local pipeline to save time
                bat """
                    call ${VENV_DIR}\\Scripts\\activate.bat
                    set PYTHONUTF8=1
                    python ml/train.py
                """
            }
            post {
                success {
                    archiveArtifacts artifacts: 'models/*.pkl', fingerprint: true
                }
            }
        }

        // ── STAGE 6: Deploy Service ───────────────────────────────────────────
        stage('Deploy Service') {
            when {
                branch 'main'
            }
            steps {
                echo 'Deployment stage (Simulation for local Windows)'
                bat """
                    echo "In a real environment, BentoML would be started here."
                    echo "For local Windows, please run '.\\run.ps1 bento' in your terminal."
                """
            }
        }

    } // end stages

    // ── Post-pipeline actions ─────────────────────────────────────────────────
    post {
        success {
            echo """
╔══════════════════════════════════════════╗
║   FlowGuard AI Pipeline – SUCCESS ✅     ║
║   FastAPI: http://localhost:8000/docs    ║
║   BentoML: http://localhost:3000         ║
║   MLflow:  http://localhost:5000         ║
╚══════════════════════════════════════════╝
"""
        }
        failure {
            echo '❌  Pipeline FAILED — review the logs above'
            // emailext body: 'FlowGuard AI build failed. Check Jenkins.',
            //     subject: 'FlowGuard CI Failure',
            //     to: 'devops@flowguard.ai'
        }
        always {
            cleanWs()   // Clean workspace after every build
        }
    }

} // end pipeline
